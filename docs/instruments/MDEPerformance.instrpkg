        </create-table>
        <create-table>
            <id>mde-table-markdown_parse</id>
            <schema-ref>mde-schema-markdown_parse</schema-ref>
        </create-table>
        <create-table>
            <id>mde-table-markdown_style</id>
            <schema-ref>mde-schema-markdown_style</schema-ref>
        </create-table>
        <create-table>
            <id>mde-table-markdown_style_incremental</id>
            <schema-ref>mde-schema-markdown_style_incremental</schema-ref>
        </create-table>
        <create-table>
            <id>mde-table-sync_perform</id>
            <schema-ref>mde-schema-sync_perform</schema-ref>
        </create-table>

        <graph>
            <title>Vault</title>
            <lane>
                <title>vault_refresh_all</title>
                <table-ref>mde-table-vault_refresh_all</table-ref>
            </lane>
            <lane>
                <title>vault_update_note</title>
