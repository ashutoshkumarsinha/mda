  <instrument>
        <id>name.aks.mde.signposts</id>
        <title>MDE Signposts</title>
        <category>Performance</category>
        <purpose>Interval durations for MDE vault, editor, and sync signposts</purpose>
        <icon>Time</icon>

        <create-table>
            <id>mde-table-vault_refresh_all</id>
            <schema-ref>mde-schema-vault_refresh_all</schema-ref>
        </create-table>
        <create-table>
            <id>mde-table-vault_reload_notes</id>
            <schema-ref>mde-schema-vault_reload_notes</schema-ref>
        </create-table>
        <create-table>
            <id>mde-table-vault_reload_tag_tree</id>
            <schema-ref>mde-schema-vault_reload_tag_tree</schema-ref>
        </create-table>
